manifest {
    name = 'import_large_geojson'
    description = 'Import large GeoJSON cell annotations into QuPath projects in headless mode'
    author = 'WEHI SODA Hub'
    version = '0.1.0'
    mainScript = 'main.nf'
    nextflowVersion = '!>=24.04.0'
}

process {
    executor = 'local'
    cpus = 4
    memory = '32 GB'
    time = '12h'
}

docker.enabled = false
singularity.enabled = false
conda.enabled = false

profiles {
    // Default — targets med/il nodes (28-48 cores, 491GB)
    standard {
        process {
            executor = 'slurm'
            queue = 'regular'
            errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
            maxRetries = 1
            withLabel: 'process_heavy' {
                cpus   = { 8 }
                memory = { 240.GB * task.attempt }     // med/il: 491GB (240*2=480GB)
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    // Targets sml nodes (28 cores, 113GB)
    small {
        process {
            executor = 'slurm'
            queue = 'regular'
            errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
            maxRetries = 1
            withLabel: 'process_heavy' {
                cpus   = { 8 }
                memory = { 50.GB * task.attempt }      // sml: 113GB (50*2=100GB)
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    // Targets med nodes (28 cores, 491GB) / il nodes (48 cores, 491GB)
    medium {
        process {
            executor = 'slurm'
            queue = 'regular'
            errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
            maxRetries = 1
            withLabel: 'process_heavy' {
                cpus   = { 14 }                        // half of med 28 cores
                memory = { 240.GB * task.attempt }     // med/il: 491GB (240*2=480GB)
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    // Targets lrg nodes (64 cores, 1498GB)
    large {
        process {
            executor = 'slurm'
            queue = 'regular'
            errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
            maxRetries = 1
            withLabel: 'process_heavy' {
                cpus   = { 16 }                        // 1/4 of lrg 64 cores
                memory = { 700.GB * task.attempt }     // lrg: 1498GB (700*2=1400GB)
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
}
