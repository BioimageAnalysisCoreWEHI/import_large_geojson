manifest {
    name = 'import_large_geojson'
    description = 'Import large GeoJSON cell annotations into QuPath projects in headless mode'
    author = 'WEHI SODA Hub'
    version = '0.1.0'
    mainScript = 'main.nf'
    nextflowVersion = '!>=24.04.0'
}

process {
    executor = 'local'
    cpus = 4
    memory = '32 GB'
    time = '12h'
}

docker.enabled = false
singularity.enabled = false
conda.enabled = false

profiles {
    standard {
        process {
            executor = 'slurm'
            queue = 'regular'
            withLabel: 'process_heavy' {
                cpus   = { 4 }
                memory = { 450.GB * task.attempt }
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    small {
        process {
            executor = 'slurm'
            queue = 'regular'
            withLabel: 'process_heavy' {
                cpus   = { 4 }
                memory = { 128.GB * task.attempt }
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    medium {
        process {
            executor = 'slurm'
            queue = 'regular'
            withLabel: 'process_heavy' {
                cpus   = { 4 }
                memory = { 480.GB * task.attempt }
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }

    large {
        process {
            executor = 'slurm'
            queue = 'regular'
            withLabel: 'process_heavy' {
                cpus   = { 8 }
                memory = { 1200.GB * task.attempt }
                time   = { 48.h }
            }
        }
        executor {
            queueSize = 10
            submitRateLimit = '10 sec'
        }
    }
}
